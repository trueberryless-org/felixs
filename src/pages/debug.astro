---
import BaseHead from "@/layouts/BaseHead.astro";
import {
  fetchBluesky,
  fetchBooks,
  fetchEvents,
  fetchPosts,
  fetchProjects,
} from "@/lib/data";

export const prerender = false;

Astro.response.headers.set("Cache-Control", "no-store");

const [posts, books, events, bluesky, projects] = await Promise.allSettled([
  fetchPosts(),
  fetchBooks(),
  fetchEvents(),
  fetchBluesky(),
  fetchProjects(),
]);

const sections: { label: string; result: PromiseSettledResult<any> }[] = [
  { label: "Posts", result: posts },
  { label: "Books", result: books },
  { label: "Events", result: events },
  { label: "Bluesky Posts", result: bluesky },
  { label: "Projects", result: projects },
];

const summarize = (item: any): string => {
  if (typeof item === "string") return item;
  if (item?.title) return item.title;
  if (item?.name) return item.name;
  if (item?.text)
    return item.text.substring(0, 60) + (item.text.length > 60 ? "…" : "");
  if (item?.data?.title) return item.data.title;
  if (item?.data?.name) return item.data.name;
  if (item?.id) return item.id;
  return JSON.stringify(item).substring(0, 60);
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <BaseHead
      title="Debug Mode | Felix Schneider"
      description="View the website with raw data"
    />
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
      }
      details {
        background: #f4f4f4;
        padding: 0.5rem;
        margin-bottom: 0.5rem;
        border-radius: 4px;
      }
      summary {
        cursor: pointer;
        font-weight: bold;
      }
      pre {
        white-space: pre-wrap;
        word-wrap: break-word;
        font-size: 0.85rem;
      }
      .error {
        color: #900;
        padding: 1rem;
        background: #fee;
        border-radius: 4px;
        margin: 0.5rem 0;
      }
      .empty {
        color: #666;
        font-style: italic;
        padding: 1rem;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Live Overview (All Data Dump)</h1>
      {
        sections.map(({ label, result }) => (
          <section>
            <h2>{label}</h2>
            {result.status === "rejected" && (
              <div class="error">
                <strong>Error loading {label.toLowerCase()}:</strong>{" "}
                {String(result.reason?.message || result.reason)}
              </div>
            )}
            {result.status === "fulfilled" && !result.value && (
              <div class="empty">No {label.toLowerCase()} returned.</div>
            )}
            {result.status === "fulfilled" &&
              Array.isArray(result.value) &&
              result.value.map((item: any) => (
                <details>
                  <summary>{summarize(item)}</summary>
                  <pre>{JSON.stringify(item, null, 2)}</pre>
                </details>
              ))}
            {result.status === "fulfilled" &&
              result.value &&
              !Array.isArray(result.value) && (
                <details>
                  <summary>{summarize(result.value)}</summary>
                  <pre>{JSON.stringify(result.value, null, 2)}</pre>
                </details>
              )}
          </section>
        ))
      }
    </main>
  </body>
</html>
