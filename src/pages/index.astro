---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/landing/Hero.astro";
import Intro from "@/components/landing/Intro.astro";
import RecentPosts from "@/components/landing/RecentPosts.astro";
import RecentBlueskyPosts from "@/components/landing/RecentBlueskyPosts.astro";
import ReadingSummary from "@/components/landing/ReadingSummary.astro";
import UpcomingEvents from "@/components/landing/UpcomingEvents.astro";
import SectionSkeleton from "@/components/utils/SectionSkeleton.astro";
---

<Layout title="Felix Schneider">
  <Hero name="Felix Schneider" />

  <div class="content-wrapper layout-stream">
    <Intro />
    <RecentPosts server:defer>
      <SectionSkeleton
        slot="fallback"
        title="Recent Blog Posts"
        description="Longer-form writing and notes published through my AT Protocol feed."
        rows={3}
      />
    </RecentPosts>
    <ReadingSummary server:defer>
      <SectionSkeleton
        slot="fallback"
        title="Bookshelf"
        description="I like to read books and I catalog them in bookhive."
        rows={4}
      />
    </ReadingSummary>
    <UpcomingEvents server:defer>
      <SectionSkeleton
        slot="fallback"
        title="Upcoming Events"
        description="Community meetups and conferences I'm planning to attend."
        rows={1}
      />
    </UpcomingEvents>
    <RecentBlueskyPosts server:defer>
      <SectionSkeleton
        slot="fallback"
        title="Bluesky"
        description="Short thoughts I share on the decentralized social web."
        rows={4}
      />
    </RecentBlueskyPosts>
  </div>
</Layout>

<style>
  .layout-stream {
    position: relative;
    z-index: 10;
    padding-top: 80px;
    padding-bottom: 80px;
  }
</style>
