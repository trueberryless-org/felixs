---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/landing/Hero.astro";
import Intro from "@/components/landing/Intro.astro";
import RecentPosts from "@/components/landing/RecentPosts.astro";
import RecentBlueskyPosts from "@/components/landing/RecentBlueskyPosts.astro";
import ReadingSummary from "@/components/landing/ReadingSummary.astro";
import UpcomingEvents from "@/components/landing/UpcomingEvents.astro";
import {
  buildReadingSummary,
  fetchBluesky,
  fetchBooks,
  fetchEvents,
  fetchPosts,
} from "@/lib/data";

export const prerender = true;

const [posts, books, events, bluesky] = await Promise.all([
  fetchPosts().catch(() => null),
  fetchBooks().catch(() => null),
  fetchEvents().catch(() => null),
  fetchBluesky().catch(() => null),
]);

const summary = books ? buildReadingSummary(books) : null;
---

<Layout title="Felix Schneider">
  <Hero name="Felix Schneider" />

  <div class="content-wrapper layout-stream">
    <Intro />
    <RecentPosts posts={posts} />
    <ReadingSummary summary={summary} />
    <UpcomingEvents events={events} />
    <RecentBlueskyPosts posts={bluesky} />
  </div>
</Layout>

<script>
  import "@/scripts/hydrate";
</script>

<style>
  .layout-stream {
    position: relative;
    z-index: 10;
    padding-top: 80px;
    padding-bottom: 80px;
  }
</style>
