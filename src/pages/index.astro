---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/landing/Hero.astro";
import Intro from "@/components/landing/Intro.astro";
import RecentPosts from "@/components/landing/RecentPosts.astro";
import RecentPostsSkeleton from "@/components/landing/RecentPostsSkeleton.astro";
import RecentBlueskyPosts from "@/components/landing/RecentBlueskyPosts.astro";
import RecentBlueskyPostsSkeleton from "@/components/landing/RecentBlueskyPostsSkeleton.astro";
import ReadingSummary from "@/components/landing/ReadingSummary.astro";
import ReadingSummarySkeleton from "@/components/landing/ReadingSummarySkeleton.astro";
import UpcomingEvents from "@/components/landing/UpcomingEvents.astro";
import UpcomingEventsSkeleton from "@/components/landing/UpcomingEventsSkeleton.astro";

export const prerender = true;
---

<Layout title="Felix Schneider">
  <Hero name="Felix Schneider" />

  <div class="content-wrapper layout-stream">
    <Intro />
    <RecentPosts server:defer>
      <RecentPostsSkeleton slot="fallback" />
    </RecentPosts>
    <ReadingSummary server:defer>
      <ReadingSummarySkeleton slot="fallback" />
    </ReadingSummary>
    <UpcomingEvents server:defer>
      <UpcomingEventsSkeleton slot="fallback" />
    </UpcomingEvents>
    <RecentBlueskyPosts server:defer>
      <RecentBlueskyPostsSkeleton slot="fallback" />
    </RecentBlueskyPosts>
  </div>
</Layout>

<style>
  .layout-stream {
    position: relative;
    z-index: 10;
    padding-top: 80px;
    padding-bottom: 80px;
  }
</style>
