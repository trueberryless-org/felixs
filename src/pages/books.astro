---
import LayoutBreadcrumbs from "@/layouts/LayoutBreadcrumbs.astro";
import Book from "@/components/books/Book.astro";
import PageHeader from "@/components/utils/PageHeader.astro";
import { getLibraryBooks } from "@/lib/books";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, s-maxage=604800, stale-while-revalidate=31536000"
);

const books = await getLibraryBooks();
---

<LayoutBreadcrumbs title="Bookshelf | Felix Schneider">
  <PageHeader title="Bookshelf">
    <Fragment slot="description">
      I like to read a little bit and track finished books on <a
        href="https://bookhive.buzz"
        target="_blank"
        rel="noopener noreferrer">bookhive</a
      >.
    </Fragment>
  </PageHeader>
  <div class="books-grid">
    {
      books.map((book) => (
        <Book
          title={book.title}
          authors={book.authors}
          coverUrl={book.coverUrl}
          rotation={book.rotation}
          hiveId={book.hiveId}
          thickness={book.thickness}
        />
      ))
    }
  </div>
</LayoutBreadcrumbs>

<style>
  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 4rem 2.5rem;
    padding-top: 1rem;
    padding-bottom: 2rem;
  }
</style>
