---
import LayoutPage from "@/layouts/LayoutPage.astro";
import BooksContent from "@/components/books/BooksContent.astro";
import BooksSkeleton from "@/components/books/BooksSkeleton.astro";
import Breadcrumbs from "@/components/utils/Breadcrumbs.astro";

export const prerender = true;
---

<LayoutPage title="Bookshelf | Felix Schneider">
  <div class="page-head">
    <div>
      <h1>Bookshelf</h1>
      <p class="description">
        I read fantasy and fiction. My reading list is tracked on <a
          href="https://bookhive.buzz/profile/felixs.dev"
          target="_blank"
          rel="noopener noreferrer">Bookhive</a
        >.
      </p>
    </div>
    <Breadcrumbs />
  </div>

  <BooksContent server:defer>
    <BooksSkeleton slot="fallback" />
  </BooksContent>
</LayoutPage>

<style>
  .description {
    margin-top: 0.5rem;
  }

  .description a {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
