---
import LayoutPage from "@/layouts/LayoutPage.astro";
import BlogContent from "@/components/blog/BlogContent.astro";
import BlogSkeleton from "@/components/blog/BlogSkeleton.astro";
import PageHeader from "@/components/utils/PageHeader.astro";

export const prerender = true;
---

<LayoutPage title="Blog | Felix Schneider">
  <PageHeader title="Blog Posts">
    <Fragment slot="description">
      I write recipes, notes and longer thoughts on <a
        href="https://leaflet.pub/p/felixs.dev"
        target="_blank"
        rel="noopener noreferrer">Leaflet</a
      >.
    </Fragment>
  </PageHeader>

  <BlogContent server:defer>
    <BlogSkeleton slot="fallback" />
  </BlogContent>
</LayoutPage>
