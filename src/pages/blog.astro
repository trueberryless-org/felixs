---
import LayoutPage from "@/layouts/LayoutPage.astro";
import BlogContent from "@/components/blog/BlogContent.astro";
import BlogSkeleton from "@/components/blog/BlogSkeleton.astro";
import Breadcrumbs from "@/components/utils/Breadcrumbs.astro";

export const prerender = true;
---

<LayoutPage title="Blog | Felix Schneider">
  <div class="page-head">
    <h1>Blog Posts</h1>
    <Breadcrumbs />
  </div>

  <BlogContent server:defer>
    <BlogSkeleton slot="fallback" />
  </BlogContent>
</LayoutPage>
