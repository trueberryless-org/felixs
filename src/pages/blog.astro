---
import LayoutPage from "@/layouts/LayoutPage.astro";
import BlogContent from "@/components/blog/BlogContent.astro";
import BlogSkeleton from "@/components/blog/BlogSkeleton.astro";
import Breadcrumbs from "@/components/utils/Breadcrumbs.astro";

export const prerender = true;
---

<LayoutPage title="Blog | Felix Schneider">
  <div class="page-head">
    <div>
      <h1>Blog Posts</h1>
      <p class="description">
        I write recipes, notes and longer thoughts on <a href="https://leaflet.pub/p/felixs.dev" target="_blank" rel="noopener noreferrer">Leaflet</a>.
      </p>
    </div>
    <Breadcrumbs />
  </div>

  <BlogContent server:defer>
    <BlogSkeleton slot="fallback" />
  </BlogContent>
</LayoutPage>

<style>
  .description {
    margin-top: 0.5rem;
  }

  .description a {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
