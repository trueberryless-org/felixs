---
import LayoutPage from "@/layouts/LayoutPage.astro";
import ProjectsContent from "@/components/projects/ProjectsContent.astro";
import Fallback from "@/components/utils/Fallback.astro";
import { fetchProjects } from "@/lib/data";

export const prerender = true;

const data = await fetchProjects().catch((err) => {
  console.error("[projects] build-time fetch failed:", err);
  return null;
});

const buildDate = new Date().toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<LayoutPage title="Projects | Felix Schneider">
  <div class="page-head">
    <h1>Open Source</h1>
    {data && <span class="build-note">Updated {buildDate}</span>}
  </div>

  {
    data ? (
      <ProjectsContent data={data} />
    ) : (
      <Fallback
        description="I couldn't reach GitHub during the last build. You can browse my repositories directly on GitHub."
        fallbackHref="https://github.com/trueberryless"
        fallbackLabel="See my GitHub profile"
      />
    )
  }
</LayoutPage>

<style>
  .page-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
  }

  .build-note {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-style: italic;
  }
</style>
