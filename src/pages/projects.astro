---
import LayoutBreadcrumbs from "@/layouts/LayoutBreadcrumbs.astro";
import Projects from "@/components/projects/Projects.astro";
import PageHeader from "@/components/utils/PageHeader.astro";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=86400, stale-while-revalidate=7776000"
);
Astro.response.headers.set(
  "CDN-Cache-Control",
  "public, max-age=604800, stale-while-revalidate=7776000"
);
---

<LayoutBreadcrumbs title="Projects | Felix Schneider">
  <div class="projects-wrapper">
    <PageHeader title="Open Source">
      <Fragment slot="description">
        It's about the fun and community. Take a look at what I do on my <a
          href="https://github.com/trueberryless"
          target="_blank"
          rel="noopener noreferrer">GitHub</a
        >.
      </Fragment>
    </PageHeader>

    <Projects server:defer>
      <div slot="fallback" class="loading-indicator">
        Loading projects from GitHub...
      </div>
    </Projects>
  </div>
</LayoutBreadcrumbs>

<style>
  .projects-wrapper {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .loading-indicator {
    padding: 48px;
    text-align: center;
    font-style: italic;
    color: var(--text-muted);
  }
</style>
