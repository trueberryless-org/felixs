---
import LayoutPage from "@/layouts/LayoutPage.astro";
import ProjectsContent from "@/components/projects/ProjectsContent.astro";
import ProjectsSkeleton from "@/components/projects/ProjectsSkeleton.astro";
import Breadcrumbs from "@/components/utils/Breadcrumbs.astro";

export const prerender = true;
---

<LayoutPage title="Projects | Felix Schneider">
  <div class="page-head">
    <h1>Open Source</h1>
    <Breadcrumbs />
  </div>

  <ProjectsContent server:defer>
    <ProjectsSkeleton slot="fallback" />
  </ProjectsContent>
</LayoutPage>

<style>
  .page-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
  }

  h1 {
    margin: 0;
  }
</style>
