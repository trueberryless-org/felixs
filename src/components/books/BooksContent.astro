---
import Book from "@/components/books/Book.astro";
import Fallback from "@/components/utils/Fallback.astro";
import { fetchBooks } from "@/lib/data";

const books = await fetchBooks().catch(() => null);
const hasData = Boolean(books && books.length > 0);
---

{
  hasData ? (
    <div class="books-grid">
      {books!.map((book) => (
        <Book
          title={book.title}
          authors={book.authors}
          coverUrl={book.coverUrl}
          rotation={book.rotation}
          hiveId={book.hiveId}
          thickness={book.thickness}
        />
      ))}
    </div>
  ) : (
    <Fallback
      description="My reading log lives on ATproto through Bookhive and isn't reachable right now. You can browse it directly on Bookhive."
      fallbackHref="https://bookhive.buzz/profile/felixs.dev"
      fallbackLabel="Browse my bookshelf on Bookhive"
    />
  )
}

<style>
  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 4rem 2.5rem;
    padding-top: 1rem;
    padding-bottom: 2rem;
  }
</style>
