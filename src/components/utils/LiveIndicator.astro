---
interface Props {
  status?: "loading" | "static" | "live" | "failed";
  "data-for"?: string;
}

const { status = "loading", "data-for": dataFor } = Astro.props;
---

<span class="live-indicator" data-status={status} data-for={dataFor}>
  <span class="dot"></span>
  <span class="label">
    {status === "loading" && "Loading…"}
    {status === "static" && "Cached"}
    {status === "live" && "Live"}
    {status === "failed" && "Offline"}
  </span>
</span>

<style is:global>
  .live-indicator {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
    user-select: none;
  }

  .live-indicator .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-muted);
    opacity: 0.5;
    transition: background 0.3s ease;
  }

  .live-indicator[data-status="loading"] .dot {
    animation: live-pulse 1.4s ease-in-out infinite;
  }

  .live-indicator[data-status="live"] .dot {
    background: oklch(0.7 0.18 145);
    animation: live-glow 2.4s ease-in-out infinite;
    opacity: 1;
  }

  .live-indicator[data-status="failed"] {
    display: none;
  }

  @keyframes live-pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.9;
    }
  }

  @keyframes live-glow {
    0%,
    100% {
      box-shadow: 0 0 0 0 oklch(0.7 0.18 145 / 0.5);
    }
    50% {
      box-shadow: 0 0 0 4px oklch(0.7 0.18 145 / 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .live-indicator .dot {
      animation: none !important;
    }
  }
</style>
