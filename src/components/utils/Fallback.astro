---
interface Props {
  description: string;
  fallbackHref: string;
  fallbackLabel: string;
}

const { description, fallbackHref, fallbackLabel } = Astro.props;
---

<div class="fallback">
  <p class="fallback-title">Content unavailable</p>
  <p class="fallback-description">{description}</p>
  <a
    href={fallbackHref}
    target="_blank"
    rel="noopener noreferrer"
    class="fallback-link"
  >
    {fallbackLabel}
    <span class="arrow">→</span>
  </a>
</div>

<style>
  .fallback {
    border: 1px dashed var(--border);
    border-radius: var(--radius-card);
    background: var(--card-bg);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .fallback-title {
    font-weight: 600;
    color: var(--text);
    font-size: 1rem;
    margin: 0;
  }

  .fallback-description {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  .fallback-link {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 16px;
    font-size: 0.85rem;
    color: var(--text);
    background: var(--badge-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    text-decoration: none;
    margin-top: 4px;
    transition: opacity 0.2s ease;
  }

  .fallback-link:hover {
    opacity: 0.8;
  }

  .fallback-link .arrow {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .fallback-link:hover .arrow {
    transform: translateX(4px);
  }
</style>
