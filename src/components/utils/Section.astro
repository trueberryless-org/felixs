---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<section class="section-container">
  <div class="section-header">
    <div class="header-titles">
      <h2>{title}</h2>
      {description && <p class="section-description">{description}</p>}
    </div>
    <div class="header-actions">
      <slot name="header-actions" />
    </div>
  </div>
  <div class="block-content">
    <slot />
  </div>
</section>

<style>
  .section-container {
    width: 100%;
    margin-bottom: 56px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 20px;
  }

  .header-titles {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  h2 {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .header-actions {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    padding-top: 4px;
  }

  .block-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
</style>
