---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  href: string;
  text: string;
  icon?: ImageMetadata;
  alt?: string;
  name?: string;
}

const { href, text, icon, alt = "Badge icon", name } = Astro.props;

const isExternal = /^(https?:)?\/\//i.test(href) || href.startsWith("mailto:");
const badgeClass = ["badge", name ? `badge-${name}` : null]
  .filter(Boolean)
  .join(" ");
---

<a
  href={href}
  class={badgeClass}
  {...isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {}}
>
  {icon && <Image src={icon} alt={alt} width={128} />}
  <span>{text}</span>
</a>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.2em 0.4em;
    margin: 0 -0.05em;
    height: 1.6em;
    font-size: 0.95em;
    vertical-align: middle;
    transform: translateY(-0.1em);

    background: var(--badge-bg);
    backdrop-filter: blur(8px);
    border-radius: 4px;

    text-decoration: none;
    color: var(--text);
    font-weight: 500;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .badge:hover {
    background: var(--card-bg);
    box-shadow: var(--lift-shadow);
  }

  .badge :global(img),
  .badge :global(svg) {
    width: 1.1em;
    height: 1.1em;
    border-radius: 2px;
    object-fit: contain;
  }

  /* Optical alignment nudges for logos with off-center visual weight. */
  .badge-astro :global(img) {
    transform: translateY(-0.05em);
    margin-top: -0.05em;
  }

  @media (prefers-reduced-motion: reduce) {
    .badge {
      transition: none;
    }
    .badge:hover {
      transform: translateY(-0.1em);
    }
  }
</style>
