---
interface Props {
  title: string;
  description?: string;
  rows?: number;
}

const { title, description, rows = 3 } = Astro.props;
---

<section class="section-container">
  <div class="section-header">
    <div class="header-titles">
      <h2>{title}</h2>
      {description && <p class="section-description">{description}</p>}
    </div>
  </div>
  <div class="block-content">
    <div class="skeleton-list">
      {
        Array.from({ length: rows }).map(() => (
          <div class="skeleton-item">
            <div class="skeleton-line skeleton-main" />
            <div class="skeleton-line skeleton-meta" />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-container {
    width: 100%;
    margin-bottom: 56px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
  }

  .header-titles {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  h2 {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .skeleton-list {
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    background: var(--card-bg);
    overflow: hidden;
  }

  .skeleton-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    gap: 16px;
  }

  .skeleton-item:last-child {
    border-bottom: none;
  }

  .skeleton-line {
    background: var(--border);
    border-radius: 4px;
    animation: skeleton-pulse 1.5s ease-in-out infinite;
  }

  .skeleton-main {
    height: 16px;
    flex: 1;
    max-width: 60%;
  }

  .skeleton-meta {
    height: 14px;
    width: 80px;
    flex-shrink: 0;
  }

  @keyframes skeleton-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }
</style>
