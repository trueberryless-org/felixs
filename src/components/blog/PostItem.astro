---
import { processPost } from "@/lib/posts";
import ExternalIcon from "@/components/utils/ExternalIcon.astro";

const { post } = Astro.props;
const { title, formattedDate, postUrl, firstTag, otherTags } = processPost(post);

const lastSpaceIdx = title.lastIndexOf(' ');
const titleStart = lastSpaceIdx !== -1 ? title.slice(0, lastSpaceIdx + 1) : '';
const titleEnd = lastSpaceIdx !== -1 ? title.slice(lastSpaceIdx + 1) : title;
---

<article class="post-item">
  <a href={postUrl} target="_blank" rel="noopener noreferrer" class="post-link">
    <div class="post-title-container">
      <h3 class="post-title">
        {titleStart}<span class="nowrap">{titleEnd}<span class="post-external"><ExternalIcon size={11} /></span></span>
      </h3>
    </div>

    <div class="post-meta">
      <time datetime={post.data.publishedAt} class="post-meta-item">
        {formattedDate.toLowerCase()}
      </time>

      {
        firstTag && (
          <>
            <span class="post-separator">&bull;</span>
            <span class="post-meta-item">{firstTag}</span>
          </>
        )
      }

      {
        Array.isArray(otherTags) ? (
          otherTags.map((tag) => (
            <>
              <span class="post-separator">&bull;</span>
              <span class="post-meta-item">{tag}</span>
            </>
          ))
        ) : typeof otherTags === "string" ? (
          otherTags.split(",").map((tag) => (
            tag.trim() ? (
              <>
                <span class="post-separator">&bull;</span>
                <span class="post-meta-item">{tag.trim()}</span>
              </>
            ) : null
          ))
        ) : otherTags ? (
          <>
            <span class="post-separator">&bull;</span>
            <span class="post-meta-item">{otherTags}</span>
          </>
        ) : null
      }
    </div>
  </a>
</article>

<style>
  .post-link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 0;
    transition: opacity 0.2s ease;
    text-decoration: none;
  }

  @media (min-width: 768px) {
    .post-link {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
    }
  }

  .post-link:hover {
    opacity: 0.7;
  }

  .post-title-container {
    flex: 1 1 auto;
    min-width: 0;
  }

  .post-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.4;
    display: inline;
    word-break: break-word;
  }

  .nowrap {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

  .post-external {
    color: var(--text-muted);
    display: flex;
    flex-shrink: 0;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px;
    flex-shrink: 0;
  }

  .post-separator {
    color: var(--text-muted);
    opacity: 0.8;
    user-select: none;
    font-size: 1.2em;
  }

  .post-meta-item {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-family: ui-monospace, SFMono-Regular, monospace;
    letter-spacing: 0.05em;
    text-transform: none;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .post-separator {
      display: none;
    }
    .post-meta {
      flex-direction: row;
      flex-wrap: wrap;
      row-gap: 6px;
      column-gap: 12px;
      padding-left: 4px;
    }
    .post-meta-item {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .post-meta-item::before {
      content: '/';
      color: var(--text-muted);
      opacity: 0.5;
      font-weight: bold;
    }
    .post-meta-item:first-child::before {
      content: '↳';
    }
  }
</style>
