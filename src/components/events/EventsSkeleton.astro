---
const count = 4;
---

<div class="skeleton-timeline">
  {
    Array.from({ length: count }).map(() => (
      <div class="skeleton-event">
        <div class="skeleton-date">
          <div class="skeleton-line date-day" />
          <div class="skeleton-line date-weekday" />
        </div>

        <div class="skeleton-marker">
          <div class="skeleton-dot" />
        </div>

        <div class="skeleton-card">
          <div class="skeleton-content">
            <div class="skeleton-line time" />
            <div class="skeleton-line title" />
            <div class="skeleton-line loc" />

            <div class="skeleton-avatars">
              <div class="skeleton-avatar" />
              <div class="skeleton-avatar" />
              <div class="skeleton-avatar" />
              <div class="skeleton-avatar" />
              <div class="skeleton-avatar" />
            </div>
          </div>

          <div class="skeleton-image" />
        </div>
      </div>
    ))
  }
</div>

<style>
  .skeleton-timeline {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .skeleton-event {
    display: flex;
    flex-direction: row;
    width: 100%;
    margin-bottom: 40px;
    position: relative;
    box-sizing: border-box;
  }

  .skeleton-date {
    width: 120px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    padding-top: 24px;
  }

  .skeleton-marker {
    width: 40px;
    flex-shrink: 0;
    position: relative;
    display: flex;
    justify-content: center;
  }

  .skeleton-marker::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: -40px;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    border-left: 1px dashed var(--border);
  }

  .skeleton-event:last-child .skeleton-marker::before {
    bottom: 0;
  }

  .skeleton-dot {
    position: absolute;
    top: 32px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--border);
    z-index: 2;
  }

  .skeleton-card {
    flex: 1;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: stretch;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    min-width: 0;
    overflow: hidden;
  }

  .skeleton-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    min-width: 0;
    padding: 24px;
  }

  .skeleton-line {
    background: var(--border);
    border-radius: 4px;
    animation: skeleton-pulse 1.5s ease-in-out infinite;
  }

  .skeleton-line.date-day {
    height: 22px;
    width: 50px;
  }

  .skeleton-line.date-weekday {
    height: 16px;
    width: 70px;
    margin-top: 4px;
  }

  .skeleton-line.time {
    height: 16px;
    width: 110px;
    margin-bottom: 12px;
  }

  .skeleton-line.title {
    height: 28px;
    width: 65%;
    margin-bottom: 12px;
  }

  .skeleton-line.loc {
    height: 16px;
    width: 40%;
    margin-bottom: 24px;
  }

  .skeleton-avatars {
    display: flex;
    align-items: center;
  }

  .skeleton-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid var(--card-bg);
    background: var(--border);
    margin-left: -8px;
    animation: skeleton-pulse 1.5s ease-in-out infinite;
  }

  .skeleton-avatar:first-child {
    margin-left: 0;
  }

  .skeleton-image {
    width: 200px;
    flex-shrink: 0;
    border-left: 1px solid var(--border);
    background: var(--border);
    animation: skeleton-pulse 1.5s ease-in-out infinite;
  }

  @keyframes skeleton-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  @media (max-width: 768px) {
    .skeleton-event {
      flex-direction: column;
      margin-bottom: 32px;
    }

    .skeleton-date {
      width: 100%;
      flex-direction: row;
      gap: 12px;
      padding-top: 0;
      margin-bottom: 12px;
      align-items: baseline;
    }

    .skeleton-line.date-weekday {
      margin-top: 0;
    }

    .skeleton-marker {
      display: none;
    }

    .skeleton-card {
      flex-direction: column;
    }

    .skeleton-content {
      padding: 20px;
    }

    .skeleton-image {
      width: 100%;
      height: 180px;
      border-left: none;
      border-bottom: 1px solid var(--border);
      order: -1;
    }
  }
</style>
