---
import Section from "@/components/utils/Section.astro";
import Card from "@/components/projects/Card.astro";
import { getOwnProjects, getContributedProjects } from "@/lib/github";

const [contributedProjects, ownProjects] = await Promise.all([
  getContributedProjects(),
  getOwnProjects(),
]);
---

{
  contributedProjects.length > 0 && (
    <Section
      title="Contributions"
      description="Open source projects I've meaningfully contributed to, ordered by activity."
    >
      <div class="projects-grid">
        {contributedProjects.map((project) => (
          <Card {...project} />
        ))}
      </div>
    </Section>
  )
}

{
  ownProjects.length > 0 && (
    <Section
      title="Personal creations"
      description="Repositories I started and maintain myself — from web apps to small tools."
    >
      <div class="projects-grid">
        {ownProjects.map((project) => (
          <Card {...project} />
        ))}
      </div>
    </Section>
  )
}

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
