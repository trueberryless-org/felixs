---
import Section from "@/components/utils/Section.astro";
import Card from "@/components/projects/Card.astro";

interface Project {
  name: string;
  description?: string | null;
  url: string;
  stars?: number;
  contributions?: number;
}

interface Props {
  data: {
    ownProjects: Project[];
    contributedProjects: Project[];
  };
}

const { data } = Astro.props;
---

{
  data.contributedProjects.length > 0 && (
    <Section title="Contributions">
      <div class="projects-grid">
        {data.contributedProjects.map((p) => (
          <Card {...p} />
        ))}
      </div>
    </Section>
  )
}

{
  data.ownProjects.length > 0 && (
    <Section title="Personal creations">
      <div class="projects-grid">
        {data.ownProjects.map((p) => (
          <Card {...p} />
        ))}
      </div>
    </Section>
  )
}

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
