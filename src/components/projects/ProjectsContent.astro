---
import Section from "@/components/utils/Section.astro";
import Card from "@/components/projects/Card.astro";
import Fallback from "@/components/utils/Fallback.astro";
import { fetchProjects } from "@/lib/data";

const data = await fetchProjects().catch((err) => {
  console.error("[projects] fetch failed:", err);
  return null;
});
---

{
  data ? (
    <>
      {data.contributedProjects.length > 0 && (
        <Section title="Contributions">
          <div class="projects-grid">
            {data.contributedProjects.map((p) => (
              <Card {...p} />
            ))}
          </div>
        </Section>
      )}

      {data.ownProjects.length > 0 && (
        <Section title="Personal creations">
          <div class="projects-grid">
            {data.ownProjects.map((p) => (
              <Card {...p} />
            ))}
          </div>
        </Section>
      )}
    </>
  ) : (
    <Fallback
      description="I couldn't reach GitHub right now. You can browse my repositories directly on GitHub."
      fallbackHref="https://github.com/trueberryless"
      fallbackLabel="See my GitHub profile"
    />
  )
}

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
