---
import { Image } from "astro:assets";

import astroLight from "@/assets/logos/light/astro.png";
import npmxLight from "@/assets/logos/light/npmx.png";
import starlightLight from "@/assets/logos/light/starlight.png";
import catppuccinLight from "@/assets/logos/light/catppuccin.png";
import emdashLight from "@/assets/logos/light/emdash-cms.png";
import astroDark from "@/assets/logos/dark/astro.png";
import npmxDark from "@/assets/logos/dark/npmx.png";
import starlightDark from "@/assets/logos/dark/starlight.png";
import catppuccinDark from "@/assets/logos/dark/catppuccin.png";
import emdashDark from "@/assets/logos/dark/emdash-cms.png";

interface Props {
  name: string;
}

const { name } = Astro.props;
---

<section class="hero-viewport" id="hero-section">
  <div class="hexagon-space">
    <div
      class="hex"
      style="top: -5%; left: 65%; --size: 280px; z-index: 1; --speed: 0.73;"
    >
    </div>
    <div
      class="hex"
      style="top: 20%; left: 7%; --size: 400px; z-index: 2; --b-width: 3px; --speed: 0.61;"
    >
    </div>
    <div
      class="hex"
      style="top: 55%; left: 72%; --size: 220px; z-index: 30; --b-width: 3px; --b-style: dashed; --speed: 0.38;"
    >
    </div>
    <div
      class="hex"
      style="top: 61%; left: -4%; --size: 300px; z-index: 4; --b-style: dashed; --speed: 0.48;"
    >
    </div>
    <div
      class="hex"
      style="top: 58%; left: 35%; --size: 180px; z-index: 5; --speed: 0.53;"
    >
    </div>
    <div
      class="hex"
      style="top: 25%; left: 52%; --size: 120px; z-index: 6; --b-style: dashed; --b-width: 3px; --speed: 0.41;"
    >
    </div>
  </div>

  <div class="floating-logos">
    <div class="logo-parallax" style="top: 15%; left: 35%; --speed: 0.58;">
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="logo-wrapper logo-astro"
        style="animation-delay: 0s;"
        aria-label="Astro"
      >
        <Image src={astroLight} alt="Astro Logo" class="tech-logo light-logo" />
        <Image src={astroDark} alt="Astro Logo" class="tech-logo dark-logo" />
      </a>
    </div>
    <div class="logo-parallax" style="top: 75%; left: 57%; --speed: 0.34;">
      <a
        href="https://npmx.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="logo-wrapper"
        style="animation-delay: -1.4s;"
        aria-label="npmx"
      >
        <Image src={npmxLight} alt="npmx Logo" class="tech-logo light-logo" />
        <Image src={npmxDark} alt="npmx Logo" class="tech-logo dark-logo" />
      </a>
    </div>
    <div class="logo-parallax" style="top: 80%; left: 25%; --speed: 0.27;">
      <a
        href="https://starlight.astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="logo-wrapper"
        style="animation-delay: -3.1s;"
        aria-label="Starlight"
      >
        <Image
          src={starlightLight}
          alt="Starlight Logo"
          class="tech-logo light-logo"
        />
        <Image
          src={starlightDark}
          alt="Starlight Logo"
          class="tech-logo dark-logo"
        />
      </a>
    </div>
    <div class="logo-parallax" style="top: 41%; left: 5%; --speed: 0.39;">
      <a
        href="https://catppuccin.com"
        target="_blank"
        rel="noopener noreferrer"
        class="logo-wrapper"
        style="animation-delay: -4.8s;"
        aria-label="Catppuccin"
      >
        <Image
          src={catppuccinLight}
          alt="Catppuccin Logo"
          class="tech-logo light-logo"
        />
        <Image
          src={catppuccinDark}
          alt="Catppuccin Logo"
          class="tech-logo dark-logo"
        />
      </a>
    </div>
    <div class="logo-parallax" style="top: 25%; left: 77%; --speed: 0.52;">
      <a
        href="https://www.emdashcms.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="logo-wrapper"
        style="animation-delay: -4.5s;"
        aria-label="EmDash CMS"
      >
        <Image
          src={emdashLight}
          alt="EmDash Logo"
          class="tech-logo light-logo"
        />
        <Image src={emdashDark} alt="EmDash Logo" class="tech-logo dark-logo" />
      </a>
    </div>
  </div>

  <div class="hero-center-wrapper" id="hero-content">
    <div class="hero-blur" aria-hidden="true"></div>
    <h1 class="hero-text">{name}</h1>
  </div>
</section>

<style is:global>
  main {
    padding-top: 0;
    min-height: 0;
  }
</style>

<style>
  .hero-viewport {
    position: relative;
    width: 100vw;
    max-width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
  }

  .hexagon-space {
    position: absolute;
    /* On small viewports the space still overhangs the hero by 8%; on wide
       viewports it caps at a fixed box so the hexagons cluster tighter. */
    width: min(116%, 1400px);
    height: min(116%, 1000px);
    /* Center without `transform` so this element does NOT create a stacking
       context. That lets each hex's own z-index compete directly with the
       hero text (20) and floating logos (40) — e.g. the dashed hex at
       z-index 30 sits in front of the text but behind the logos. */
    left: calc(50% - min(116%, 1400px) / 2);
    top: calc(50% - min(116%, 1000px) / 2);
    pointer-events: none;
  }

  .hex {
    --b-width: 2px;
    --b-color: var(--text-muted);
    --b-style: dotted;

    position: absolute;
    width: var(--size);
    height: calc(var(--size) * 1.1547);
    background: var(--bg-subtle);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    box-sizing: border-box;
    border-left: var(--b-width) var(--b-style) var(--b-color);
    border-right: var(--b-width) var(--b-style) var(--b-color);
    will-change: transform;
    transform: translate3d(0, calc(var(--scroll-y) * var(--speed, 0)), 0);
  }

  .hex::before,
  .hex::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(var(--b-width) * -1);
    right: calc(var(--b-width) * -1);
    box-sizing: border-box;
    border-left: var(--b-width) var(--b-style) var(--b-color);
    border-right: var(--b-width) var(--b-style) var(--b-color);
  }

  .hex::before {
    transform: rotate(60deg);
  }

  .hex::after {
    transform: rotate(120deg);
  }

  .floating-logos {
    position: absolute;
    top: 50%;
    left: 50%;
    /* Same idea as .hexagon-space: fluid on small screens, capped on huge ones
       so logos overlap more and the depth reads better. */
    width: min(100%, 1180px);
    height: min(100%, 860px);
    transform: translate(-50%, -50%);
    z-index: 40;
    pointer-events: none;
  }

  :root:not(.dark) .dark-logo {
    display: none;
  }

  :root.dark .light-logo {
    display: none;
  }

  .logo-parallax {
    position: absolute;
    will-change: transform;
    transform: translate3d(0, calc(var(--scroll-y) * var(--speed, 0)), 0);
    pointer-events: auto;
  }

  .logo-wrapper {
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--border);
    border-radius: 16px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow:
      0 8px 32px oklch(0.2 0.02 60 / 0.12),
      inset 0 1px 0 oklch(1 0 0 / 0.25);
    animation: floatLogo 6s ease-in-out infinite;
    transition:
      transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  :root.dark .logo-wrapper {
    background: oklch(0.24 0.008 250);
    border: 1px solid oklch(0.42 0.01 250);
    box-shadow:
      0 10px 28px oklch(0 0 0 / 0.55),
      0 2px 6px oklch(0 0 0 / 0.5),
      inset 0 1px 0 oklch(1 0 0 / 0.08),
      inset 0 -1px 0 oklch(0 0 0 / 0.4);
  }

  .logo-wrapper:hover {
    transform: translateY(-4px);
    box-shadow:
      0 16px 42px oklch(0.2 0.02 60 / 0.22),
      inset 0 1px 0 oklch(1 0 0 / 0.3);
    border-color: var(--text-muted);
  }

  :root.dark .logo-wrapper:hover {
    box-shadow:
      0 16px 42px oklch(0 0 0 / 0.7),
      0 2px 6px oklch(0 0 0 / 0.5),
      inset 0 1px 0 oklch(1 0 0 / 0.12),
      inset 0 -1px 0 oklch(0 0 0 / 0.4);
    border-color: oklch(0.55 0.01 250);
  }

  .tech-logo {
    width: 60%;
    height: 60%;
    object-fit: contain;
    transition:
      filter 0.3s ease,
      opacity 0.3s ease;
  }

  @keyframes floatLogo {
    0%,
    100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-16px) rotate(3deg);
    }
  }

  .hero-center-wrapper {
    position: relative;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    transform: translate3d(0, calc(var(--scroll-y) * 0.5), 0);
  }

  .hero-blur {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(90vw, 900px);
    height: 100%;
    min-height: 260px;
    transform: translate(-50%, -50%);
    z-index: 1;
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 40%,
      transparent 80%
    );
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    pointer-events: none;
  }

  .hero-text {
    position: relative;
    z-index: 2;
    font-family:
      "Datatype", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      "Liberation Mono", "Courier New", monospace;
    font-size: clamp(3.25rem, 8vw, 7.5rem);
    font-weight: 900;
    letter-spacing: -0.045em;
    line-height: 1.05;
    text-align: center;
    margin: 0;
    padding: 40px 60px;
    color: var(--text);
  }

  @supports ((-webkit-background-clip: text) or (background-clip: text)) {
    .hero-text {
      background-image: var(--text-gradient);
      background-repeat: no-repeat;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hex,
    .logo-parallax,
    .hero-center-wrapper {
      transform: none !important;
    }

    .logo-wrapper {
      animation: none !important;
      transition: none;
    }

    .logo-wrapper:hover {
      transform: none;
    }
  }

  @media (prefers-reduced-transparency: reduce) {
    .logo-wrapper {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: var(--bg-subtle);
    }

    .hero-blur {
      display: none;
    }
  }
</style>
