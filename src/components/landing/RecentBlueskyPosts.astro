---
import Section from "@/components/utils/Section.astro";
import Fallback from "@/components/utils/Fallback.astro";
import LiveIndicator from "@/components/utils/LiveIndicator.astro";
import ListSkeleton from "@/components/landing/ListSkeleton.astro";
import RecentBlueskyPostsInner from "@/components/landing/RecentBlueskyPostsInner.astro";
import ActionLink from "@/components/utils/ActionLink.astro";
import { actorDid } from "@/lib/const";
import type { BlueskyPost } from "@/lib/data";

interface Props {
  posts: BlueskyPost[] | null;
  displayLimit?: number;
}

const { posts, displayLimit = 4 } = Astro.props;
const hasData = Boolean(posts && posts.length > 0);
---

<Section title="Bluesky">
  <div slot="header-actions" class="header-cluster">
    <LiveIndicator status={hasData ? "static" : "loading"} />
    <ActionLink
      href={`https://bsky.app/profile/${actorDid}`}
      text="View profile"
    />
  </div>
  <div
    class="hydrate"
    data-hydrate="landing/bluesky"
    data-state={hasData ? "static" : "loading"}
  >
    <div data-content>
      {
        hasData ? (
          <RecentBlueskyPostsInner posts={posts!} displayLimit={displayLimit} />
        ) : (
          <ListSkeleton rows={4} />
        )
      }
    </div>
    <div data-fallback>
      <Fallback
        description="My most-liked recent Bluesky posts usually appear here."
        fallbackHref={`https://bsky.app/profile/${actorDid}`}
        fallbackLabel="Open my Bluesky profile"
      />
    </div>
  </div>
</Section>

<style>
  .header-cluster {
    display: flex;
    align-items: center;
    gap: 12px;
  }
</style>
