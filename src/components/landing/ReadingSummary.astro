---
import Section from "@/components/utils/Section.astro";
import Fallback from "@/components/utils/Fallback.astro";
import LiveIndicator from "@/components/utils/LiveIndicator.astro";
import ListSkeleton from "@/components/landing/ListSkeleton.astro";
import ReadingSummaryInner from "@/components/landing/ReadingSummaryInner.astro";
import ActionLink from "@/components/utils/ActionLink.astro";
import type { ReadingSummary } from "@/lib/data";

interface Props {
  summary: ReadingSummary | null;
}

const { summary } = Astro.props;
const hasData = Boolean(summary);
---

<Section title="Reading Summary">
  <div slot="header-actions" class="header-cluster">
    <LiveIndicator status={hasData ? "static" : "loading"} />
    <ActionLink href="/books" text="View all" />
  </div>
  <div
    class="hydrate"
    data-hydrate="landing/reading-summary"
    data-state={hasData ? "static" : "loading"}
  >
    <div data-content>
      {
        summary ? (
          <ReadingSummaryInner summary={summary} />
        ) : (
          <ListSkeleton rows={4} />
        )
      }
    </div>
    <div data-fallback>
      <Fallback
        description="I track my reading through Bookhive on ATproto."
        fallbackHref="https://bookhive.buzz/profile/felixs.dev"
        fallbackLabel="Browse my bookshelf on Bookhive"
      />
    </div>
  </div>
</Section>

<style>
  .header-cluster {
    display: flex;
    align-items: center;
    gap: 12px;
  }
</style>
