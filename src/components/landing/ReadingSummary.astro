---
import Section from "@/components/utils/Section.astro";
import ActionLink from "@/components/utils/ActionLink.astro";
import List from "@/components/utils/List.astro";
import Fallback from "@/components/utils/Fallback.astro";
import { buildReadingSummary, fetchBooks } from "@/lib/data";

const books = await fetchBooks().catch(() => null);
const summary = books ? buildReadingSummary(books) : null;
---

<Section title="Reading Summary">
  <ActionLink slot="header-actions" href="/books" text="View all" />
  {
    summary ? (
      <List>
        <li class="list-item">
          <span class="item-main">{summary.latest.title}</span>
          <span class="item-meta">
            {summary.latest.startedAt
              ? `Started: ${new Date(summary.latest.startedAt).toLocaleDateString("en-US")}`
              : "Started: Unknown"}
          </span>
        </li>
        {summary.favorites.map((book) => (
          <li class="list-item">
            <span class="item-main">{book.title}</span>
            <span class="item-meta">{(book.stars ?? 0) / 2} stars</span>
          </li>
        ))}
      </List>
    ) : (
      <Fallback
        description="I track my reading through Bookhive on ATproto."
        fallbackHref="https://bookhive.buzz/profile/felixs.dev"
        fallbackLabel="Browse my bookshelf on Bookhive"
      />
    )
  }
</Section>
