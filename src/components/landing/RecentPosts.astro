---
import Section from "@/components/utils/Section.astro";
import Fallback from "@/components/utils/Fallback.astro";
import LiveIndicator from "@/components/utils/LiveIndicator.astro";
import ListSkeleton from "@/components/landing/ListSkeleton.astro";
import RecentPostsInner from "@/components/landing/RecentPostsInner.astro";
import ActionLink from "@/components/utils/ActionLink.astro";
import type { AugmentedPost } from "@/lib/data";

interface Props {
  posts: AugmentedPost[] | null;
}

const { posts } = Astro.props;
const hasData = Boolean(posts && posts.length > 0);
---

<Section title="Recent Blog Posts">
  <div slot="header-actions" class="header-cluster">
    <LiveIndicator status={hasData ? "static" : "loading"} />
    <ActionLink href="/blog" text="View all" />
  </div>
  <div
    class="hydrate"
    data-hydrate="landing/recent-posts"
    data-state={hasData ? "static" : "loading"}
  >
    <div data-content>
      {
        hasData ? (
          <RecentPostsInner posts={posts!} />
        ) : (
          <ListSkeleton rows={3} />
        )
      }
    </div>
    <div data-fallback>
      <Fallback
        description="My blog posts live on ATproto. Once the required domains are reachable they'll appear here."
        fallbackHref="https://leaflet.pub/p/felixs.dev"
        fallbackLabel="Read on Leaflet"
      />
    </div>
  </div>
</Section>

<style>
  .header-cluster {
    display: flex;
    align-items: center;
    gap: 12px;
  }
</style>
