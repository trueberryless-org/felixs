---
import Section from "@/components/utils/Section.astro";
import ActionLink from "@/components/utils/ActionLink.astro";
import List from "@/components/utils/List.astro";
import Fallback from "@/components/utils/Fallback.astro";
import { fetchPosts } from "@/lib/data";
import { processPost } from "@/lib/posts";

const posts = await fetchPosts().catch(() => null);
const items =
  posts && posts.length > 0
    ? [...posts]
        .sort(
          (a, b) =>
            new Date(b.data.publishedAt).getTime() -
            new Date(a.data.publishedAt).getTime()
        )
        .slice(0, 3)
    : null;
---

<Section title="Recent Blog Posts">
  <ActionLink slot="header-actions" href="/blog" text="View all" />
  {
    items ? (
      <List>
        {items.map((post) => {
          const { title, postUrl } = processPost(post);
          return (
            <li class="list-item clickable">
              <a
                href={postUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="post-link"
              >
                <div class="item-left">
                  <span class="item-main">{title}</span>
                </div>
                <span class="arrow">→</span>
              </a>
            </li>
          );
        })}
      </List>
    ) : (
      <Fallback
        description="My blog posts live on ATproto. Once the required domains are reachable they'll appear here."
        fallbackHref="https://leaflet.pub/p/felixs.dev"
        fallbackLabel="Read on Leaflet"
      />
    )
  }
</Section>

<style>
  .post-link {
    display: flex;
    width: 100%;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
</style>
