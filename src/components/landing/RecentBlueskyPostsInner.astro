---
import { Heart } from "@lucide/astro";
import List from "@/components/utils/List.astro";

interface Post {
  postUrl: string;
  text: string;
  likes: number;
  createdAt: string;
}

interface Props {
  posts: Post[];
  displayLimit?: number;
}

const { posts, displayLimit = 4 } = Astro.props;
const items = [...posts]
  .sort((a, b) => b.likes - a.likes)
  .slice(0, displayLimit)
  .sort(
    (a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
  );
---

<List>
  {
    items.map((post) => (
      <li class="list-item clickable">
        <a
          href={post.postUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bsky-link"
        >
          <span class="bsky-item-main">
            <span class="bsky-text">{post.text}</span>
          </span>
          <span class="bsky-meta">
            <Heart class="bsky-icon" />
            <span>{post.likes}</span>
          </span>
        </a>
      </li>
    ))
  }
</List>

<style>
  .bsky-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    text-decoration: none;
    color: inherit;
    gap: 1.5rem;
  }
  .bsky-item-main {
    display: flex;
    align-items: center;
    min-width: 0;
    flex: 1;
    word-break: break-word;
  }
  .bsky-text {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
  }
  .bsky-meta {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--text-muted);
    font-weight: 500;
    flex-shrink: 0;
  }
  .bsky-icon {
    width: 14px;
    height: 14px;
    display: block;
  }
</style>
