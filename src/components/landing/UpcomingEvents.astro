---
import Section from "@/components/utils/Section.astro";
import ActionLink from "@/components/utils/ActionLink.astro";
import List from "@/components/utils/List.astro";
import ExternalIcon from "@/components/utils/ExternalIcon.astro";
import { fetchEvents } from "@/lib/data";
import { applyCache, degradedCache, longLivedCache } from "@/lib/cache";

const events = await fetchEvents().catch(() => null);
applyCache(Astro.response, events ? longLivedCache : degradedCache);
const now = Date.now();
const items = events
  ? events
      .map((e) => ({ ...e, startDate: new Date(e.startDate) }))
      .filter((e) => e.startDate.getTime() > now)
      .sort((a, b) => a.startDate.getTime() - b.startDate.getTime())
      .slice(0, 3)
  : [];
const hasUpcoming = items.length > 0;
---

{
  hasUpcoming && (
    <Section title="Upcoming Events">
      <ActionLink slot="header-actions" href="/events" text="View all" />
      <List>
        {items.map((event) => (
          <li class="list-item clickable">
            <a
              href={event.atmoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="event-link"
            >
              <div class="item-left">
                <span class="item-main">
                  {event.data.name || "Untitled Network Event"}
                </span>
              </div>
              <ExternalIcon class="row-icon" />
            </a>
          </li>
        ))}
      </List>
    </Section>
  )
}

<style>
  .event-link {
    display: flex;
    width: 100%;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    color: inherit;
    gap: 12px;
  }

  .row-icon {
    color: var(--text-muted);
    flex-shrink: 0;
  }
</style>
