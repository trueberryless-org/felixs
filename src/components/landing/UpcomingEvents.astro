---
import { getProcessedEvents } from "@/lib/events";
import Section from "@/components/utils/Section.astro";
import List from "@/components/utils/List.astro";
import ActionLink from "@/components/utils/ActionLink.astro";
import ExternalIcon from "@/components/utils/ExternalIcon.astro";

const allEvents = await getProcessedEvents();

const upcomingEvents = allEvents
  .filter((e) => !e.isPast)
  .sort((a, b) => a.startDate.getTime() - b.startDate.getTime())
  .slice(0, 3);
---

{
  upcomingEvents.length > 0 && (
    <Section
      title="Upcoming Events"
      description="Community meetups and conferences I'm planning to attend."
    >
      <ActionLink slot="header-actions" href="/events" text="View all" />

      <List>
        {upcomingEvents.map((event) => (
          <li class="list-item clickable">
            <a
              href={event.atmoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="event-link"
            >
              <div class="item-left">
                <span class="item-main">
                  {event.data.name || "Untitled Network Event"}
                </span>
              </div>
              <ExternalIcon class="row-icon" />
            </a>
          </li>
        ))}
      </List>
    </Section>
  )
}

<style>
  .event-link {
    display: flex;
    width: 100%;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    color: inherit;
    gap: 12px;
  }

  .row-icon {
    color: var(--text-muted);
    flex-shrink: 0;
  }
</style>
