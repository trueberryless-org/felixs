---
import Section from "@/components/utils/Section.astro";
import Fallback from "@/components/utils/Fallback.astro";
import LiveIndicator from "@/components/utils/LiveIndicator.astro";
import ListSkeleton from "@/components/landing/ListSkeleton.astro";
import UpcomingEventsInner from "@/components/landing/UpcomingEventsInner.astro";
import type { Event } from "@/lib/data";

interface Props {
  events: Event[] | null;
}

const { events } = Astro.props;
const now = Date.now();
const hasUpcoming = Boolean(
  events && events.some((e) => new Date(e.startDate).getTime() > now)
);
---

<Section title="Upcoming Events">
  <LiveIndicator
    slot="header-actions"
    status={hasUpcoming ? "static" : "loading"}
  />
  <div
    class="hydrate"
    data-hydrate="landing/upcoming-events"
    data-state={hasUpcoming ? "static" : "loading"}
  >
    <div data-content>
      {
        hasUpcoming ? (
          <UpcomingEventsInner events={events!} />
        ) : (
          <ListSkeleton rows={2} />
        )
      }
    </div>
    <div data-fallback>
      <Fallback
        description="My RSVPs live on ATproto."
        fallbackHref="https://atmo.rsvp/p/did:plc:pbjvqaziagcyv2vqodldn5op"
        fallbackLabel="See my RSVPs on atmo.rsvp"
      />
    </div>
  </div>
</Section>
